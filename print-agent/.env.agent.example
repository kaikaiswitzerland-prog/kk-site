# ─── print-agent/.env.agent ────────────────────────────────────────────
# Copie ce fichier en `print-agent/.env.agent` (sans .example) et remplis
# les variables. Le vrai .env.agent est gitignoré : NE JAMAIS le committer.

# URL de ton projet Supabase
# Supabase dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé service_role Supabase (SECRET — équivaut à un admin de la base)
# Supabase dashboard → Project Settings → API → Project API keys → service_role
# Cette clé bypass les RLS. C'est voulu : l'agent tourne en local, jamais exposé.
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# URL ePOS-Print de l'imprimante TM-m30II (HTTP, pas HTTPS — pas de cert à approuver)
# Adapte l'IP si l'imprimante a une autre adresse sur le réseau local.
PRINTER_URL=http://192.168.1.103/cgi-bin/epos/service.cgi?devid=local_printer&timeout=10000

# Intervalle de polling Supabase, en ms (5000 = un check toutes les 5 secondes)
POLL_MS=5000
