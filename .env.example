# =============================================================
# KaïKaï — Variables d'environnement (template)
# =============================================================
# Copier ce fichier en .env.local pour le développement local.
# En production, ces variables sont définies dans Vercel
# (Settings → Environment Variables — Production + Preview).
# NE JAMAIS commiter .env.local ou .env (ignorés par git).
#
# Note de nommage : le projet utilise le préfixe NEXT_PUBLIC_* pour les
# variables exposées au client (configuré dans vite.config.js via
# envPrefix), pas VITE_*. Conserve ce préfixe pour les variables front.

# ─── Supabase (base de données + auth) ──────────────────────────
# Front (publique, exposée au client) :
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Serveur uniquement (bypass RLS — ne JAMAIS exposer au client).
# Utilisé par api/_lib/supabaseServer.js pour les Vercel Functions.
SUPABASE_SERVICE_ROLE_KEY=

# ─── SumUp (paiement carte) ─────────────────────────────────────
# Clé API privée + merchant code. Utilisés par api/create-checkout.js,
# api/sumup-webhook.js et api/sumup-refund.js.
SUMUP_SECRET_KEY=
SUMUP_MERCHANT_CODE=

# ─── Resend (emails transactionnels) ────────────────────────────
# Utilisé par api/_lib/resend.js pour les emails de confirmation et
# de remboursement.
RESEND_API_KEY=
